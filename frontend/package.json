{
  "name": "erudi",
  "productName": "erudi",
  "version": "1.0.0",
  "description": "Erudi is a modern, windows desktop application designed to query and fine-tune models locally, on a no-code friendly-user interface and with your own data.",
  "main": ".webpack/main",
  "scripts": {
    "start": "concurrently -k -n main,preload,rndr,elec \"npm:dev:main\" \"npm:dev:preload\" \"npm:dev:renderer\" \"npm:dev:electron\"",
    "dev:main": "cross-env NODE_ENV=development webpack --config webpack.config.js --config-name main --watch",
    "dev:preload": "cross-env NODE_ENV=development webpack --config webpack.config.js --config-name preload --watch",
    "dev:renderer": "cross-env NODE_ENV=development webpack serve --config webpack.config.js --config-name renderer",
    "dev:electron": "wait-on http://localhost:3000 .webpack/main/index.js && electron .",
    "build": "cross-env NODE_ENV=production webpack --config webpack.config.js",
    "dist:win": "npm run build && electron-builder --win --config electron-builder.yml",
    "dist:mac": "npm run build && electron-builder --mac --config electron-builder.yml",
    "dist:linux": "npm run build && electron-builder --linux --config electron-builder.yml",
    "release:win": "npm run build && electron-builder --win --config electron-builder.yml --publish always",
    "release:mac": "npm run build && electron-builder --mac --config electron-builder.yml --publish always",
    "release:linux": "npm run build && electron-builder --linux --config electron-builder.yml --publish always",
    "lint": "eslint src --ext .js,.jsx --fix",
    "lint:check": "eslint src --ext .js,.jsx",
    "format": "prettier --write \"src/**/*.{js,jsx,css,md}\"",
    "format:check": "prettier --check \"src/**/*.{js,jsx,css,md}\"",
    "test": "vitest",
    "test:run": "vitest run"
  },
  "keywords": [],
  "author": "Djalil Chikhi, Rayan Hanader, Sami Taider, Youssef Chaouki, Youssef Laatar",
  "license": "SEE LICENSE IN LICENSE",
  "devDependencies": {
    "@babel/core": "^7.27.1",
    "@babel/preset-react": "^7.27.1",
    "@tailwindcss/postcss": "^4.1.5",
    "@vercel/webpack-asset-relocator-loader": "1.7.3",
    "autoprefixer": "^10.4.21",
    "babel-loader": "^10.0.0",
    "concurrently": "^9.1.2",
    "cross-env": "^7.0.3",
    "css-loader": "^6.11.0",
    "electron": "^36.1.0",
    "electron-builder": "^26.0.12",
    "eslint": "^8.56.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-react": "^7.33.2",
    "eslint-plugin-react-hooks": "^4.6.0",
    "html-webpack-plugin": "^5.6.3",
    "node-loader": "^2.1.0",
    "playwright": "^1.61.0",
    "postcss": "^8.5.3",
    "postcss-loader": "^8.1.1",
    "prettier": "^3.1.1",
    "style-loader": "^3.3.4",
    "tailwindcss": "^3.4.17",
    "vitest": "^4.1.9",
    "wait-on": "^8.0.3",
    "webpack": "^5.99.9",
    "webpack-cli": "^5.1.4",
    "webpack-dev-server": "^4.15.2"
  },
  "dependencies": {
    "@fontsource/montserrat": "^5.2.8",
    "@tailwindcss/aspect-ratio": "^0.4.2",
    "@tailwindcss/forms": "^0.5.10",
    "@tailwindcss/typography": "^0.5.16",
    "electron-log": "^5.4.3",
    "electron-squirrel-startup": "^1.0.1",
    "electron-updater": "^6.8.3",
    "framer-motion": "^12.11.3",
    "lucide-react": "^0.507.0",
    "prop-types": "^15.8.1",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "react-markdown": "^10.1.0",
    "react-router-dom": "^7.5.3",
    "remark-gfm": "^4.0.1"
  }
}
