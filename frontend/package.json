{
  "name": "erudi",
  "productName": "erudi",
  "version": "1.0.0",
  "description": "Erudi is a modern, windows desktop application designed to query and fine-tune models locally, on a no-code friendly-user interface and with your own data.",
  "main": ".webpack/main",
  "scripts": {
    "start": "electron-forge start",
    "package": "electron-forge package",
    "make": "electron-forge make",
    "dist:win": "electron-forge package --platform win32 --arch x64 && electron-builder --prepackaged out/erudi-win32-x64 --config electron-builder.yml",
    "dist:mac": "electron-forge package --platform darwin --arch arm64 && electron-builder --prepackaged out/erudi-darwin-arm64 --config electron-builder.yml",
    "release:win": "electron-forge package --platform win32 --arch x64 && electron-builder --prepackaged out/erudi-win32-x64 --config electron-builder.yml --publish always",
    "release:mac": "electron-forge package --platform darwin --arch arm64 && electron-builder --prepackaged out/erudi-darwin-arm64 --config electron-builder.yml --publish always",
    "publish": "electron-forge publish",
    "lint": "eslint src --ext .js,.jsx --fix",
    "lint:check": "eslint src --ext .js,.jsx",
    "format": "prettier --write \"src/**/*.{js,jsx,css,md}\"",
    "format:check": "prettier --check \"src/**/*.{js,jsx,css,md}\""
  },
  "keywords": [],
  "author": "Djalil Chikhi, Rayan Hanader, Sami Taider, Youssef Chaouki, Youssef Laatar",
  "license": "SEE LICENSE IN LICENSE",
  "devDependencies": {
    "@babel/core": "^7.27.1",
    "@babel/preset-react": "^7.27.1",
    "@electron-forge/cli": "^7.8.0",
    "@electron-forge/maker-deb": "^7.8.0",
    "@electron-forge/maker-dmg": "^7.10.2",
    "@electron-forge/maker-rpm": "^7.8.0",
    "@electron-forge/maker-squirrel": "^7.8.0",
    "@electron-forge/maker-zip": "^7.8.0",
    "@electron-forge/plugin-auto-unpack-natives": "^7.8.0",
    "@electron-forge/plugin-fuses": "^7.8.0",
    "@electron-forge/plugin-webpack": "^7.8.0",
    "@electron/fuses": "^1.8.0",
    "@tailwindcss/postcss": "^4.1.5",
    "@vercel/webpack-asset-relocator-loader": "1.7.3",
    "autoprefixer": "^10.4.21",
    "babel-loader": "^10.0.0",
    "concurrently": "^9.1.2",
    "css-loader": "^6.11.0",
    "electron": "^36.1.0",
    "electron-builder": "^26.0.12",
    "eslint": "^8.56.0",
    "eslint-plugin-react": "^7.33.2",
    "eslint-plugin-react-hooks": "^4.6.0",
    "node-loader": "^2.1.0",
    "postcss": "^8.5.3",
    "postcss-loader": "^8.1.1",
    "prettier": "^3.1.1",
    "style-loader": "^3.3.4",
    "tailwindcss": "^3.4.17",
    "wait-on": "^8.0.3"
  },
  "dependencies": {
    "@tailwindcss/aspect-ratio": "^0.4.2",
    "@tailwindcss/forms": "^0.5.10",
    "@tailwindcss/typography": "^0.5.16",
    "electron-log": "^5.4.3",
    "electron-squirrel-startup": "^1.0.1",
    "electron-updater": "^6.8.3",
    "framer-motion": "^12.11.3",
    "lucide-react": "^0.507.0",
    "prop-types": "^15.8.1",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "react-markdown": "^10.1.0",
    "react-router-dom": "^7.5.3",
    "remark-gfm": "^4.0.1"
  }
}
